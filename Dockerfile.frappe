FROM frappe/erpnext:v15

USER frappe
WORKDIR /home/frappe/frappe-bench

# Copy cosmo_erp and install as editable package in frappe virtualenv.
# The volume mount at runtime replaces the copied files;
# the egg-link persists and still resolves to the correct path.
COPY --chown=frappe:frappe cosmo_erp/ apps/cosmo_erp/
RUN env/bin/pip install -q -e apps/cosmo_erp
