# ═══════════════════════════════════════════════════════════
# COSMO ERP — Variables d'environnement Production
# Copier en .env.prod et remplir avant déploiement
# JAMAIS committer ce fichier avec de vraies valeurs
# ═══════════════════════════════════════════════════════════

# ── ERPNext / Frappe ─────────────────────────────────────────
FRAPPE_SITE_NAME=cosmo.ma-boutique.mg
DB_ROOT_PASSWORD=CHANGEME_strong_password_here
DB_NAME=_cosmo_prod

# ── cosmo-mcp (clé API ERPNext rôle "Cosmo Hermes") ─────────
COSMO_MCP_API_KEY=CHANGEME_api_key_from_erpnext
COSMO_MCP_API_SECRET=CHANGEME_api_secret_from_erpnext

# ── Hermes Agent ─────────────────────────────────────────────
ANTHROPIC_API_KEY=CHANGEME_sk-ant-...
TELEGRAM_BOT_TOKEN=CHANGEME_from_botfather
TELEGRAM_MANAGER_ID=CHANGEME_telegram_user_id_jonathan
TELEGRAM_CASHIER_ID=CHANGEME_telegram_user_id_cashier

# ── Général ───────────────────────────────────────────────────
LOG_LEVEL=info
TZ=Indian/Antananarivo
