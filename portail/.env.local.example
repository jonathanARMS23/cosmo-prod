# ── Portail Cosmo — variables d'environnement ──────────────────────────────
# Copier ce fichier en `.env.local` (NON commité) et remplir les valeurs.

# URL interne du serveur Frappe/ERPNext (le portail y accède côté serveur uniquement).
# - Dev local : http://localhost:8081  (port nginx mappé par le docker-compose existant)
# - Prod (réseau Docker interne / Coolify) : http://frontend:8080
# NE JAMAIS préfixer par NEXT_PUBLIC_ : cette URL ne doit pas atteindre le navigateur.
ERPNEXT_URL=http://localhost:8081

# Clé de chiffrement du cookie de session (iron-session).
# DOIT faire au moins 32 caractères. Générer une vraie valeur en prod :
#   openssl rand -base64 32
# NE JAMAIS préfixer par NEXT_PUBLIC_ et ne jamais commiter la vraie clé.
SESSION_SECRET=dev-secret-change-me-please-32-chars-minimum-0000
